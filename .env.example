# ─── Frontend (Vite — values are embedded in the browser build) ───────────────
# SAFE: anon key is public by design. Never put SERVICE_ROLE_KEY here.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_API_URL=https://your-render-service.onrender.com
# Optional — Sentry DSN for client-side error tracking
# VITE_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/YYY

# ─── Backend (Render — set via Render Environment Groups or Secret Files) ──────
PORT=3001
NODE_ENV=production

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...          # Used only for JWT validation in authMiddleware
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # NEVER expose this on the frontend — backend only
SUPABASE_AUDIO_BUCKET=audio-recordings

# Google Gemini
GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=90000

# Email
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@advisorai.app

# CORS — comma-separated list of allowed frontend origins (production only)
ALLOWED_ORIGINS=https://your-app.vercel.app

# Background jobs
AUDIO_EXPIRY_DAYS=30

# Logging
LOG_LEVEL=info
