# ============================================================
# Backend — LOCAL DEVELOPMENT
# Copy this to .env and fill in your values.
# ============================================================

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-from-supabase-dashboard>
SUPABASE_JWT_SECRET=<jwt-secret-from-supabase-dashboard>

# ── Gemini ────────────────────────────────────────────────
GEMINI_API_KEY=<your-gemini-api-key>

# ── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Audio ────────────────────────────────────────────────
MAX_AUDIO_SIZE_MB=50

# ── Email (Resend) — leave empty to disable ──────────────
# Sign up at https://resend.com to get an API key.
# EMAIL_FROM must match a verified domain in your Resend account.
RESEND_API_KEY=
EMAIL_FROM=meetings@yourdomain.com

# ── App URL ───────────────────────────────────────────────
# Used to build deep-links in emails.
# For local dev, keep as localhost.
APP_URL=http://localhost:3000
