# ============================================================
# Backend — PRODUCTION (Render)
# Set these as environment variables in your Render service.
# Never commit actual values to git.
# ============================================================

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-from-supabase-dashboard>
SUPABASE_JWT_SECRET=<jwt-secret-from-supabase-dashboard>

# ── Gemini ────────────────────────────────────────────────
GEMINI_API_KEY=<your-gemini-api-key>

# ── CORS ──────────────────────────────────────────────────
# Must include your Vercel frontend URL (no trailing slash).
ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Audio ─────────────────────────────────────────────────
MAX_AUDIO_SIZE_MB=50

# ── Email (Resend) ────────────────────────────────────────
# Required for post-meeting summary emails.
# EMAIL_FROM must be a verified sender domain in Resend.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=meetings@yourdomain.com

# ── App URL ───────────────────────────────────────────────
# The public URL of your Vercel frontend.
# Used to build deep-links inside summary emails.
APP_URL=https://your-app.vercel.app
